										   <article id="post-30814" class="post-30814 page type-page status-publish has-post-thumbnail" role="article" itemscope itemtype="http://schema.org/WebPage">
	<div class="entry-content" itemprop="text">
				<div class="redesign-2024">
					<div class="free-hook-container" style="min-height:700px;background-color:#031f39"><free-hook api-url="https://bitly.com" variant="home" language="en"></free-hook></div>								
			
			<section class="full-width-content text-content no-padding-top gallery-row negative-margin-top  " style="background-image:url();background-color:#031f39">
				<div class="grid-container">
					<div class="inner-content grid-x grid-margin-x grid-padding-x">
						<div class="cell">
							<ul id="gallery-1" class="gallery galleryid-30814 gallery-columns-8 gallery-size-full "><li class="gallery-item first-in-row first-row"><figure class="gallery-icon landscape"><img width="160" height="60" src="https://mkt-static.bitly.com/static/1775093661/pages/wp-content/uploads/2024/04/curology-3.svg" class="attachment-full size-full" alt="Curology Logo" decoding="async" loading="lazy"></figure></li><li class="gallery-item  first-row"><figure class="gallery-icon landscape"><img width="160" height="60" src="https://mkt-static.bitly.com/static/1775093661/pages/wp-content/uploads/2024/04/novasol-1.svg" class="attachment-full size-full" alt="Novasol Logo" decoding="async" loading="lazy"></figure></li><li class="gallery-item  first-row"><figure class="gallery-icon landscape"><img width="160" height="60" src="https://mkt-static.bitly.com/static/1775093661/pages/wp-content/uploads/2024/04/rad-bikes-3.svg" class="attachment-full size-full" alt="Rad power Bike logo" decoding="async" loading="lazy"></figure></li><li class="gallery-item  first-row"><figure class="gallery-icon landscape"><img width="160" height="60" src="https://mkt-static.bitly.com/static/1775093661/pages/wp-content/uploads/2024/04/marriott-1.svg" class="attachment-full size-full" alt="Marriot Bonvoy Logo" decoding="async" loading="lazy"></figure></li><li class="gallery-item  first-row"><figure class="gallery-icon landscape"><img width="160" height="60" src="https://mkt-static.bitly.com/static/1775093661/pages/wp-content/uploads/2024/04/new-york-times-1.svg" class="attachment-full size-full" alt="The New York Times Logo" decoding="async" loading="lazy"></figure></li><li class="gallery-item  first-row"><figure class="gallery-icon landscape"><img width="160" height="60" src="https://mkt-static.bitly.com/static/1775093661/pages/wp-content/uploads/2024/04/smalls.svg" class="attachment-full size-full" alt="Smalls Logo" decoding="async" loading="lazy"></figure></li></ul>
<div class="clearfix"></div>
						</div>
					</div>
				</div>
			</section>
				<div class="reusable-content">		
	<section class="cards-block " style="background-color: #f7f4ee ">
		<div class="grid-container cards-inner">
							<div class="inner-content grid-x grid-margin-x grid-padding-x">
					<div class="cell">
						<div class="block-intro clearfix">
							<p class="preheading" style="text-align: center;">Great Connections Start with a click OR SCAN</p>
<h3 style="text-align: center;">The Bitly Connections Platform</h3>
<p style="text-align: center;">All the products you need to build brand connections, manage links and QR Codes, and connect with audiences everywhere, in a single unified platform.</p>
<p class="btn-group" style="text-align: center;"><a id="getStartedForFreeBtn1" class="btn" href="https://bitly.com/pages/pricing" data-testid="sdet-cta-cp-button">Get started for free</a><a id="heroGetAQuoteLnk" class="btn btn-secondary" href="https://bitly.com/pages/landing/discover-enterprise" data-testid="sdet-cta-quote-button">Get a quote</a></p>
						</div>
					</div>
				</div>
						<div class="cards-outer-wrapper inner-content grid-x grid-margin-x grid-padding-x align-center">
				
					<div class="cell large-4 flex-container">
						<div class="card">
															<div class="card-image">
									<picture>
										<source srcset="https://mkt-static.bitly.com/static/1775093661/pages/wp-content/uploads/2025/11/card-img-link.webp" media="(min-width: 1024px)">
										<img src="https://mkt-static.bitly.com/static/1775093661/pages/wp-content/uploads/2025/11/card-img-link.webp" alt="" width="780" height="740" loading="lazy">
									</source></picture>
								</div>
							
							<div class="card-section">
								<div class="inner-wrap">
																			<div class="card-title">
																							<img class="card-title__img" src="https://mkt-static.bitly.com/static/1775093661/pages/wp-content/uploads/2024/09/url-shortener-icon.webp" alt="">
																						<span>
												URL Shortener											</span>
											<img class="card-title__arrow" src="https://mkt-static.bitly.com/static/1775093661/pages/wp-content/themes/JointsWP-CSS-master/assets/images/cta-arrow-up.svg" alt="Upward facing arrow">
										</div>
																		<div class="card-description">A comprehensive solution to help make every point of connection between your content and your audience more powerful.</div>																			<div class="card-content"><p><strong>Popular URL Shortening Features</strong></p>
<ul>
